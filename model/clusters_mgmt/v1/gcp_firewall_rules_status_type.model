// Status of GCP firewall rules verification.
class GcpFirewallRulesStatus {
	// Overall state of the firewall rules (e.g. "pending", "ready", "error").
	State String

	// Human-readable description of the current status.
	Description String

	// Individual firewall rule status entries.
	Rules []GcpFirewallRulesStatusEntry
}

// Status of an individual GCP firewall rule.
struct GcpFirewallRulesStatusEntry {
	// Name of the firewall rule in GCP.
	Name String

	// Whether the firewall rule exists in GCP.
	Exists Boolean

	// Whether the firewall rule is configured correctly.
	ConfiguredCorrectly Boolean
}
